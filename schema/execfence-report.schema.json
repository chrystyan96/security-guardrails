{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/chrystyan96/execfence/master/schema/execfence-report.schema.json",
  "title": "execfence report v2/v3",
  "description": "Structured evidence bundle generated by ExecFence scan, run, doctor, and investigation commands.",
  "type": "object",
  "required": ["metadata", "command", "runtimeTrace", "config", "summary", "findings", "enrichment", "recommendedActions"],
  "additionalProperties": true,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["schemaVersion", "reportId", "generatedAt", "tool", "packageName", "packageVersion", "cwd", "projectName", "platform", "nodeVersion"],
      "properties": {
        "schemaVersion": { "enum": [2, 3] },
        "reportId": { "type": "string" },
        "generatedAt": { "type": "string" },
        "tool": { "const": "ExecFence" },
        "packageName": { "type": "string" },
        "packageVersion": { "type": "string" },
        "cwd": { "type": "string" },
        "projectName": { "type": "string" },
        "gitBranch": { "type": "string" },
        "gitCommit": { "type": "string" },
        "platform": { "type": "string" },
        "arch": { "type": "string" },
        "nodeVersion": { "type": "string" }
      }
    },
    "command": {
      "type": "object",
      "properties": {
        "display": { "type": "string" },
        "argv": { "type": "array", "items": { "type": "string" } },
        "shell": { "type": "boolean" }
      }
    },
    "runtimeTrace": {
      "type": ["object", "null"],
      "properties": {
        "display": { "type": "string" },
        "startedAt": { "type": "string" },
        "finishedAt": { "type": "string" },
        "durationMs": { "type": "number" },
        "exitCode": { "type": ["integer", "null"] },
        "preflightOk": { "type": "boolean" },
        "postflightOk": { "type": "boolean" },
        "blocked": { "type": "boolean" }
      }
    },
    "sandbox": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "ok": { "type": "boolean" },
        "mode": { "enum": ["audit", "enforce"] },
        "profile": { "enum": ["test", "build", "dev", "pack", "publish", "strict"] },
        "capabilities": { "type": "object" },
        "blockedOperations": { "type": "array" },
        "missingCapabilities": { "type": "array", "items": { "type": "string" } }
      }
    },
    "config": { "type": "object" },
    "manifest": { "type": ["object", "null"] },
    "changeRisk": { "type": "object" },
    "summary": {
      "type": "object",
      "required": ["ok", "totalFindings", "blockedFindings", "warningFindings", "suppressedFindings"],
      "properties": {
        "ok": { "type": "boolean" },
        "totalFindings": { "type": "integer" },
        "blockedFindings": { "type": "integer" },
        "warningFindings": { "type": "integer" },
        "suppressedFindings": { "type": "integer" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "file", "rule", "analysis", "research"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "column": { "type": ["integer", "null"] },
          "symbol": { "type": ["object", "null"] },
          "snippet": { "type": "string" },
          "sha256": { "type": ["string", "null"] },
          "rule": { "type": "object" },
          "analysis": { "type": "object" },
          "research": { "type": "object" }
        }
      }
    },
    "enrichment": {
      "type": "object",
      "required": ["status", "sources", "results", "errors"],
      "properties": {
        "status": { "enum": ["skipped", "failed", "partial", "complete"] },
        "sources": { "type": "array", "items": { "type": "string" } },
        "results": { "type": "array" },
        "errors": { "type": "array" }
      }
    },
    "recommendedActions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
