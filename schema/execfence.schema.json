{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/chrystyan96/execfence/master/schema/execfence.schema.json",
  "title": "execfence configuration",
  "description": "Project-level policy for execfence scans, reports, baseline exceptions, and stack-aware guardrail behavior.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "policyPack": {
      "description": "Stack-aware default policy to apply before explicit config overrides.",
      "enum": ["baseline", "web", "desktop", "node", "go", "python", "rust", "agentic", "strict"],
      "default": "baseline"
    },
    "mode": {
      "description": "Whether blocking findings fail the command or are reported only.",
      "enum": ["block", "audit"],
      "default": "block"
    },
    "blockSeverities": {
      "description": "Finding severities that fail in block mode.",
      "type": "array",
      "items": { "enum": ["critical", "high", "medium", "low"] },
      "uniqueItems": true,
      "default": ["critical", "high"]
    },
    "warnSeverities": {
      "description": "Finding severities reported as warnings when not blocked.",
      "type": "array",
      "items": { "enum": ["critical", "high", "medium", "low"] },
      "uniqueItems": true,
      "default": ["medium", "low"]
    },
    "roots": {
      "description": "Files or directories scanned when no explicit paths are passed.",
      "type": "array",
      "items": { "type": "string" }
    },
    "ignoreDirs": {
      "description": "Directory names skipped recursively.",
      "type": "array",
      "items": { "type": "string" }
    },
    "skipFiles": {
      "description": "Exact file names skipped by the scanner.",
      "type": "array",
      "items": { "type": "string" }
    },
    "allowExecutables": {
      "description": "Reviewed executable artifacts allowed in source/build-input folders. Prefer hash-pinned object entries.",
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["path", "sha256"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
              "reason": { "type": "string" }
            }
          }
        ]
      }
    },
    "extraSignatures": {
      "description": "Literal project-specific indicators to search for.",
      "type": "array",
      "items": { "type": "string" }
    },
    "extraRegexSignatures": {
      "description": "JavaScript regular expression source strings for project-specific detections.",
      "type": "array",
      "items": { "type": "string" }
    },
    "signaturesFile": {
      "description": "Path to a project/team external signatures JSON file.",
      "type": "string",
      "default": ".execfence/config/signatures.json"
    },
    "baselineFile": {
      "description": "Path to a reviewed baseline/exceptions JSON file.",
      "type": "string",
      "default": ".execfence/config/baseline.json"
    },
    "reportsDir": {
      "description": "Directory for automatic JSON evidence reports.",
      "type": "string",
      "default": ".execfence/reports"
    },
    "reportsGitignore": {
      "description": "When true, ExecFence keeps the reports directory ignored by git.",
      "type": "boolean",
      "default": true
    },
    "runtimeTrace": {
      "description": "Runtime gate trace settings for execfence run.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "postRunScan": { "type": "boolean", "default": true },
        "captureGitStatus": { "type": "boolean", "default": true },
        "redactEnv": { "type": "boolean", "default": true }
      }
    },
    "analysis": {
      "description": "Analysis and optional enrichment settings for report generation.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "webEnrichment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "automaticForSeverities": {
              "type": "array",
              "items": { "enum": ["critical", "high", "medium", "low"] },
              "uniqueItems": true,
              "default": ["critical", "high"]
            },
            "maxQueriesPerFinding": { "type": "integer", "minimum": 0, "default": 3 },
            "allowedDomains": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            },
            "timeoutMs": { "type": "integer", "minimum": 100, "default": 4000 },
            "cacheTtlMs": { "type": "integer", "minimum": 0, "default": 86400000 }
          }
        }
      }
    },
    "manifest": {
      "description": "Execution manifest and coverage policy settings.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "default": ".execfence/manifest.json" },
        "requireRunWrapper": { "type": "boolean", "default": true },
        "sensitiveEntrypoints": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["build", "test", "dev", "start", "serve", "watch", "prepare", "install", "postinstall"]
        }
      }
    },
    "trustStore": {
      "description": "Paths for reviewed trust stores.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": { "type": "string", "default": ".execfence/trust/files.json" },
        "actions": { "type": "string", "default": ".execfence/trust/actions.json" },
        "registries": { "type": "string", "default": ".execfence/trust/registries.json" }
      }
    },
    "reportRetention": {
      "description": "Local retention hints for generated evidence reports.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxReports": { "type": "integer", "minimum": 1, "default": 100 },
        "maxAgeDays": { "type": "integer", "minimum": 1, "default": 90 }
      }
    },
    "redaction": {
      "description": "Local redaction policy for evidence and external enrichment queries.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redactLocalPaths": { "type": "boolean", "default": true },
        "redactEnv": { "type": "boolean", "default": true },
        "extraPatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "workflowHardening": {
      "description": "Enable GitHub Actions hardening checks.",
      "type": "boolean",
      "default": true
    },
    "archiveAudit": {
      "description": "Report committed archives such as .zip, .tar, .tgz, and .asar in source/build-input folders.",
      "type": "boolean",
      "default": true
    },
    "auditAllPackageScripts": {
      "description": "Audit all package.json scripts instead of only install/prepare lifecycle scripts.",
      "type": "boolean",
      "default": false
    }
  }
}
