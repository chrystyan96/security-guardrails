{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/chrystyan96/execfence/master/schema/execfence-signatures.schema.json",
  "title": "execfence external signatures",
  "description": "Project or team-owned extra detections loaded through the signaturesFile setting.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "exact": {
      "description": "Literal string signatures to search for.",
      "type": "array",
      "items": { "$ref": "#/$defs/exactSignature" }
    },
    "exactSignatures": {
      "description": "Alias for exact.",
      "type": "array",
      "items": { "$ref": "#/$defs/exactSignature" }
    },
    "regex": {
      "description": "JavaScript regular expression source strings to search for.",
      "type": "array",
      "items": { "$ref": "#/$defs/regexSignature" }
    },
    "regexSignatures": {
      "description": "Alias for regex.",
      "type": "array",
      "items": { "$ref": "#/$defs/regexSignature" }
    }
  },
  "$defs": {
    "exactSignature": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "value": { "type": "string", "minLength": 1 },
            "signature": { "type": "string", "minLength": 1 },
            "reason": { "type": "string" }
          },
          "anyOf": [
            { "required": ["value"] },
            { "required": ["signature"] }
          ]
        }
      ]
    },
    "regexSignature": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "pattern": { "type": "string", "minLength": 1 },
            "value": { "type": "string", "minLength": 1 },
            "signature": { "type": "string", "minLength": 1 },
            "reason": { "type": "string" }
          },
          "anyOf": [
            { "required": ["pattern"] },
            { "required": ["value"] },
            { "required": ["signature"] }
          ]
        }
      ]
    }
  }
}
